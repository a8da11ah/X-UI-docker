# Copy this file to .env and fill in your values before `docker compose up`.

# REQUIRED. Must already have a DNS A record pointing at this host's public
# IP *before* you start the container - the installer requests a real
# Let's Encrypt cert via certbot in standalone mode on first boot.
SUBDOMAIN=vpn.example.com

# X-UI fork/version the installer pins (see x-ui-pro's readme for valid tags)
XUI_VER=v2.9.3

# Which x-ui panel fork to install: 0-3 (see x-ui-pro.sh -panel flag docs)
PANEL=1

# Country allowlist for connections. "xx" = allow all countries.
COUNTRY=xx

# yes/no - adds nginx basic auth + user-agent blocking in front of the panel
SECURE=no

# on/off - restrict panel access to Cloudflare IP ranges (only if you're
# actually proxying this host through Cloudflare)
CDN=off

# y/n - serve one of the 170+ random decoy HTML sites on the bare domain
RANDOM_TEMPLATE=n

# Leave empty. Docker already restricts the host to the ports you publish in
# docker-compose.yml, so UFW inside the container is redundant and can
# conflict with Docker's own iptables rules. Only set this if you know why
# you need it.
UFW=

# Optional extras, leave blank to skip:
TOR_COUNTRY=
WARP_COUNTRY=
WARP_LIC_KEY=
